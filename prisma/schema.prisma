generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model factory {
  id          Int          @id @default(autoincrement())
  name        String

  users       user[]
  productions production[]
  dispatches  dispatch[]
  inventories inventory[]

  createdAt   DateTime     @default(now())
}

model user {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String

  factoryId Int
  factory   factory  @relation(fields: [factoryId], references: [id])

  createdAt DateTime @default(now())
}

model production {
  id        Int      @id @default(autoincrement())

  product   String?
  rawInput  Int
  output    Int
  waste     Int

  yield     Float?

  operator  String?
  machine   String?
  shift     String?
  notes     String?

  date      DateTime @default(now())

  totalCost Float?
  profit    Float?

  // 🔥 ADDED (YOUR FIX)
  remainingQuantity Int?

  factoryId Int
  factory   factory  @relation(fields: [factoryId], references: [id])

  createdAt DateTime @default(now())
}

model dispatch {
  id        Int      @id @default(autoincrement())

  product   String
  quantity  Int
  customer  String?

  factoryId Int
  factory   factory  @relation(fields: [factoryId], references: [id])

  createdAt DateTime @default(now())
}

model inventory {
  id        Int      @id @default(autoincrement())

  material  String
  stock     Int
  unit      String   @default("kg")
  minStock  Int      @default(30)

  factoryId Int
  factory   factory  @relation(fields: [factoryId], references: [id])

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}
