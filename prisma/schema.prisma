generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // change to "sqlite" if you are using sqlite
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(uuid())
  name       String
  email      String   @unique
  password   String
  role       Role     @default(OWNER)
  factory    Factory  @relation(fields: [factoryId], references: [id])
  factoryId  String
  createdAt  DateTime @default(now())
}

model Factory {
  id          String        @id @default(uuid())
  name        String
  location    String?
  users       User[]
  productions Production[]
  inventory   Inventory?
  dispatches  Dispatch[]
  createdAt   DateTime      @default(now())
}

model Production {
  id         String   @id @default(uuid())
  factory    Factory  @relation(fields: [factoryId], references: [id])
  factoryId  String
  date       DateTime
  rawInput   Float
  output     Float
  waste      Float
  yield      Float
  createdBy  String
  createdAt  DateTime @default(now())
}

model Inventory {
  id            String   @id @default(uuid())
  factory       Factory  @relation(fields: [factoryId], references: [id])
  factoryId     String   @unique
  rawStock      Float    @default(0)
  finishedStock Float    @default(0)
  updatedAt     DateTime @updatedAt
}

model Dispatch {
  id         String          @id @default(uuid())
  factory    Factory         @relation(fields: [factoryId], references: [id])
  factoryId  String
  customer   String
  quantity   Float
  status     DispatchStatus  @default(PENDING)
  createdBy  String
  createdAt  DateTime        @default(now())
}

enum Role {
  OWNER
  MANAGER
  OPERATOR
}

enum DispatchStatus {
  PENDING
  DISPATCHED
}

